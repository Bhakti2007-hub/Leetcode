class Solution {
    public int[][] constructProductMatrix(int[][] grid) {
        int mod = 12345;
        int m = grid.length , n = grid[0].length;
        long left = 1 , right = 1;
        int[][] ans = new int[m][n];
         // top to bottom traversal
         for(int i = 0 ; i < m ; i++)
         {
            for(int j = 0 ; j < n ; j++)
            {
                ans[i][j] = (int)left ;
                left = (left*grid[i][j])%mod;
            }
         }

        // bottom to top traversal
        for(int  i = m-1 ; i>=0 ; i--)
        {
            for(int j = n-1 ; j>=0 ;j--)
            {
                ans[i][j]=(int) (right*ans[i][j])%mod;
                right = (right*grid[i][j])%mod;
            }
        }
        return ans;
        
    }
}
